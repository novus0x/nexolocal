{% extends "layouts/dashboard.njk" %}

{% block title %}Platform Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}
<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        <div class="mb-8">
            <nav class="flex mb-3 text-xs font-bold tracking-widest text-gray-500 justify-between flex-col md:flex-row gap-5"
                aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 uppercase">
                    <li class="inline-flex items-center">
                        <a href="/platform" class="hover:text-white transition-colors">Dashboard</a>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <span class="ml-1 md:ml-2 text-orange-500">Roles</span>
                        </div>
                    </li>
                </ol>
                <a href="/platform/roles/create"
                    class="bg-(--accent) hover:bg-[#ff5a26] text-white px-6 py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95">
                    <i class="fa-solid fa-plus"></i>
                    Nuevo Rol
                </a>
            </nav>
        </div>

        <div class="rounded-2xl mb-6 flex flex-col items-start justify-between gap-4">
            <div class="flex items-center gap-4">
                <div id="type-switch" class="switch-container" onclick="toggle_filter_roles()">
                    <div class="switch-slider" id="slider"></div>
                    <div class="switch-option active" id="opt-system">Plataforma</div>
                    <div class="switch-option" id="opt-user">Negocios</div>
                </div>
            </div>
        </div>

        <div class="rounded-3xl overflow-hidden glass-card">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/5 border-bottom border-(--border)">
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-(--text-muted)">
                                Nombre del Rol</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-(--text-muted)">
                                Origen</th>
                            <th
                                class="px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-(--text-muted) text-right">
                                Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm font-medium">
                        {% for role in roles %}
                        <tr class="table-row">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-4">
                                    {% if role.platform %}
                                    <div
                                        class="flex items-center justify-center w-10 h-10 bg-(--accent)/10 text-(--accent) rounded-lg">
                                        <i class="fa-solid fa-code-simple"></i>
                                    </div>
                                    {% else %}
                                    <div
                                        class="flex items-center justify-center w-10 h-10 bg-blue-500/10 text-blue-400 rounded-lg">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                    {% endif %}
                                    <div>
                                        <p class="font-bold">{{ role.name }}</p>
                                        <p class="text-[10px] text-(--text-muted) font-bold uppercase">{{ company.date
                                            }}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                {% if role.platform %}
                                <span
                                    class="text-xs bg-(--accent)/10 text-orange-400 px-2 py-1 rounded">Plataforma</span>
                                {% else %}
                                <span class="text-xs bg-blue-500/10 text-blue-400 px-2 py-1 rounded">Negocio</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center justify-end gap-2 text-(--text-muted)">
                                    {% if not company.suspended %}
                                    <a href="#{{ role.id }}"
                                        class="p-2.5 text-green-400 hover:bg-green-400/5 rounded-xl transition-all cursor-pointer"
                                        title="Editar">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="/platform/roles/update/{{ role.id }}"
                                        class="p-2.5 text-yellow-500 hover:bg-yellow-500/10 rounded-xl transition-all cursor-pointer"
                                        title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    {% else %}
                                    <button
                                        class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-xl text-xs font-bold text-green-500 transition-all cursor-pointer">Re-Activar</button>
                                    {% endif %}
                                    <a href="#{{ role.id }}"
                                        class="p-2.5 text-red-500 hover:bg-red-500/10 rounded-xl transition-all cursor-pointer">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="flex items-center justify-between mt-6">
            <span class="px-4 py-2 rounded-xl bg-white/5 text-gray-500 cursor-not-allowed">
                <i class="fa-duotone fa-regular fa-angle-left"></i> Anterior
            </span>

            <span class="text-sm text-gray-400">
                Página 1 de 1
            </span>

            <span class="px-4 py-2 rounded-xl bg-white/5 text-gray-500 cursor-not-allowed">
                Siguiente <i class="fa-duotone fa-regular fa-angle-right"></i>
            </span>
        </div>

    </div>
</main>
{% include "components/dashboard-footer.njk" %}

{% endblock %}