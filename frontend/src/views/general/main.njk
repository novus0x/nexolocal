{% extends "layouts/main.njk" %}

{% block title %}Sistema de Ventas para Negocios en Perú | NexoLocal{% endblock %}

{% block content %}

<style>
    .hero-glow {
        position: absolute;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        width: 80vw;
        height: 50vh;
        background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
        z-index: -1;
        filter: blur(80px);
    }

    .plan-carousel {
        display: flex;
        gap: 2.5rem;
        transition: transform 0.6s cubic-bezier(.22, 1, .36, 1);
        will-change: transform;
    }

    .plan-card {
        min-width: 320px;
        width: 320px;
        flex-shrink: 0;
        transition: transform 0.4s ease, opacity 0.4s ease;
    }

    .plan-locked {
        filter: grayscale(1);
        opacity: 0.35;
        pointer-events: none;
    }

    .plan-active {
        transform: scale(1.08);
        opacity: 1;
        z-index: 10;
    }

    .plan-inactive {
        transform: scale(0.95);
        opacity: 0.6;
    }

    .nav-arrow {
        background: var(--card-bg);
        border: 1px solid var(--border);
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s;
    }

    .nav-arrow:hover {
        background: white;
        color: black;
    }

    .problem-item {
        border-left: 2px solid #ef4444;
        padding-left: 1.5rem;
    }

    .solution-item {
        border-left: 2px solid #22c55e;
        padding-left: 1.5rem;
    }
</style>

<nav class="fixed top-0 w-full z-100 border-b border-white/5 backdrop-blur-lg">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="#" class="flex items-center gap-2">
            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center font-bold text-black italic">
                <img src="/public/img/logo.svg">
            </div>
            <span class="text-xl font-bold tracking-tighter">Nexo<span class="text-(--accent)">Local</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-zinc-400">
            <a href="#que-es" class="hover:text-white transition-colors">¿Qué es?</a>
            <a href="#solucion" class="hover:text-white transition-colors">Solución</a>
            <a href="#precios" class="hover:text-white transition-colors">Precios</a>
            <a href="/auth"
                class="bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95 cursor-pointer">Panel
                de Control</a>
        </div>
    </div>
</nav>

<main class="relative">
