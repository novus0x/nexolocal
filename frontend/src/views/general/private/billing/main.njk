{% extends "layouts/dashboard.njk" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}
<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        {% include "components/verify-account.njk" %}

        <div class="mb-8">
            <nav class="flex mb-3 text-xs font-bold tracking-widest text-gray-500 justify-between flex-col md:flex-row gap-5"
                aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 uppercase">
                    <li class="inline-flex items-center">
                        <a href="/dashboard" class="hover:text-white transition-colors">Dashboard</a>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <span class="ml-1 md:ml-2 text-orange-500">Pagos</span>
                        </div>
                    </li>
                </ol>
            </nav>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

            <a href="/dashboard/billing/plans"
                class="glass-card rounded-2xl p-8 transition-all duration-300 group cursor-pointer">
                <div
                    class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mb-8 group-hover:bg-orange-500/20 transition-colors border border-white/10 group-hover:border-orange-500/40">
                    <i class="fa-solid fa-layer-group text-2xl text-slate-400 group-hover:text-orange-500"></i>
                </div>
                <h3 class="text-xs font-bold text-orange-500 uppercase tracking-widest mb-2">Infraestructura</h3>
                <h2 class="text-2xl uppercase mb-4 leading-none">Planes</h2>
                <p class="text-slate-400 text-xs leading-relaxed mb-8">
                    Crea una nueva compañía desde cero adquiriendo un plan o gestiona las suscripciones de tus entidades
                    actuales.
                </p>
                <div
                    class="flex items-center text-[10px] font-bold uppercase tracking-tighter text-white/50 group-hover:text-white transition-colors">
                    <span>Gestionar o Crear</span>
                    <i class="fa-solid fa-chevron-right ml-2 text-orange-500"></i>
                </div>
            </a>

            <a href="#/dashboard/billing/add-ons"
                class="glass-card rounded-2xl p-8 transition-all duration-300 group cursor-pointer">
                <div
                    class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mb-8 group-hover:bg-orange-500/20 transition-colors border border-white/10 group-hover:border-orange-500/40">
                    <i class="fa-solid fa-plus-minus text-2xl text-slate-400 group-hover:text-orange-500"></i>
                </div>
                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Expansión (Próximamente)</h3>
                <h2 class="text-2xl uppercase mb-4 leading-none">Add-ons</h2>
                <p class="text-slate-400 text-xs leading-relaxed mb-8">
                    Cada servicio adicional se vincula directamente a un plan activo. Potencia tus capacidades según tus
                    necesidades.
                </p>
                <div
                    class="flex items-center text-[10px] font-bold uppercase tracking-tighter text-white/50 group-hover:text-white transition-colors">
                    <span>Añadir a un Plan</span>
                    <i class="fa-solid fa-chevron-right ml-2 text-orange-500"></i>
                </div>
            </a>

            <a href="/dashboard/billing/history"
                class="glass-card rounded-2xl p-8 transition-all duration-300 group cursor-pointer">
                <div
                    class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center mb-8 group-hover:bg-orange-500/20 transition-colors border border-white/10 group-hover:border-orange-500/40">
                    <i class="fa-solid fa-receipt text-2xl text-slate-400 group-hover:text-orange-500"></i>
                </div>
                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Administración</h3>
                <h2 class="text-2xl uppercase mb-4 leading-none">Pagos</h2>
                <p class="text-slate-400 text-xs leading-relaxed mb-8">
                    Historial de transacciones de todas tus compañías.
                </p>
                <div
                    class="flex items-center text-[10px] font-bold uppercase tracking-tighter text-white/50 group-hover:text-white transition-colors">
                    <span>Ver Historial</span>
                    <i class="fa-solid fa-chevron-right ml-2 text-orange-500"></i>
                </div>
            </a>
        </div>

        <section class="mt-10 space-y-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h2 class="text-xl font-bold uppercase">Acciones de Pago</h2>
                    <p class="text-xs text-slate-500 mt-1">Renueva una empresa vencida o adelanta el siguiente ciclo si deseas mantener continuidad.</p>
                </div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl border border-white/10 bg-white/5 text-[10px] font-bold uppercase tracking-[0.12em] text-slate-300">
                    <i class="fa-solid fa-clock-rotate-left text-(--accent)"></i>
                    <span>{{ billing_overview.pending_count }} registro{% if billing_overview.pending_count != 1 %}s{% endif %}</span>
                </div>
            </div>

            {% if billing_overview.items.length > 0 %}
            <div class="glass-card rounded-[2.5rem] overflow-hidden border-white/5">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/2" />
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Empresa</th>
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Plan</th>
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Próxima renovación</th>
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Monto</th>
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Estado</th>
                            <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest text-right">Acción</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            {% for item in billing_overview.items %}
                            <tr class="table-row">
                                <td class="px-8 py-6">
                                    <span class="text-sm font-bold">{{ item.company_name }}</span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-sm font-bold">{{ item.plan_name or "Sin plan" }}</span>
                                    <span class="block text-[10px] text-gray-500 uppercase">
                                        {% if item.cycle == "monthly" %}
                                        MES
                                        {% elif item.cycle == "yearly" %}
                                        AÑO
                                        {% else %}
                                        {{ item.cycle }}
                                        {% endif %}
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-sm font-bold">{{ item.date_label }}</span>
                                    <span class="block text-[10px] text-gray-500">
                                        {% if item.expired %}
                                        Venció hace {{ (item.days_left * -1) }} día{% if (item.days_left * -1) != 1 %}s{% endif %}
                                        {% else %}
                                        Renueva en {{ item.days_left }} día{% if item.days_left != 1 %}s{% endif %}
                                        {% endif %}
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-sm font-black italic">S/ {{ item.amount }}</span>
                                </td>
                                <td class="px-8 py-6">
                                    {% if item.status == "expired" %}
                                    <span class="status-badge badge-blocked">
                                        <i class="fa-solid fa-circle text-[6px]"></i> Vencida
                                    </span>
                                    {% elif item.status == "trial" %}
                                    <span class="status-badge badge-pending">
                                        <i class="fa-solid fa-circle text-[6px]"></i> Trial
                                    </span>
                                    {% else %}
                                    <span class="status-badge badge-active">
                                        <i class="fa-solid fa-circle text-[6px]"></i> Activa
                                    </span>
                                    {% endif %}
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex items-center justify-end gap-3">
                                        {% if item.can_pay_now %}
                                        <form action="/dashboard/billing/renew/{{ item.company_id }}" method="post">
                                            <button
                                                class="px-4 py-2 bg-(--accent)/10 text-(--accent) hover:bg-(--accent) hover:text-white rounded-xl text-xs font-bold transition-all cursor-pointer">
                                                {% if item.expired %}
                                                Pagar ahora
                                                {% else %}
                                                Renovar ahora
                                                {% endif %}
                                            </button>
                                        </form>
                                        {% else %}
                                        <span class="text-[10px] uppercase tracking-[0.14em] text-slate-500">
                                            {% if item.status == "trial" %}
                                            Disponible al finalizar trial
                                            {% else %}
                                            Sin acciones
                                            {% endif %}
                                        </span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="rounded-3xl border border-white/5 bg-white/2 px-6 py-5 text-xs text-slate-400 leading-relaxed">
                Si una empresa ya venció, solo se cobrará un nuevo ciclo desde la fecha de pago. Si renuevas antes del vencimiento, el nuevo ciclo se suma sobre la fecha actual de fin de suscripción.
            </div>
            {% else %}
            <div class="glass-card rounded-3xl p-8">
                <div class="flex flex-col items-center justify-center py-12 text-center">
                    <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-4 border border-white/10">
                        <i class="fa-solid fa-wallet text-slate-600 text-2xl"></i>
                    </div>
                    <p class="text-slate-400 text-sm">No hay renovaciones ni pagos por gestionar en este momento.</p>
                    <p class="text-[10px] text-slate-600 mt-1 font-semibold tracking-wide">Cuando una empresa se acerque a su fecha de renovación, aparecerá aquí.</p>
                </div>
            </div>
            {% endif %}
        </section>

    </div>
</main>
{% include "components/dashboard-footer.njk" %}

{% endblock %}
