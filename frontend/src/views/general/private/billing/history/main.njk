{% extends "layouts/dashboard.njk" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}
<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        {% include "components/verify-account.njk" %}

        <div class="mb-8">
            <nav class="flex mb-3 text-xs font-bold tracking-widest text-gray-500 justify-between flex-col md:flex-row gap-5"
                aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 uppercase">
                    <li class="inline-flex items-center">
                        <a href="/dashboard" class="hover:text-white transition-colors">Dashboard</a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <a href="/dashboard/billing" id="breadcrumb-workspace"
                                class="hover:text-white ml-1 md:ml-2 transition-colors">Pagos</a>
                        </div>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <span class="ml-1 md:ml-2 text-(--accent)">Historial de Pagos</span>
                        </div>
                    </li>
                </ol>
            </nav>
        </div>

        <div class="glass-card rounded-[2.5rem] overflow-hidden border-white/5">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/2" />
                        <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Fecha
                        </th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">ID
                            Transacción</th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Plan /
                            Concepto</th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Monto
                        </th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-500 uppercase tracking-widest">Estado
                        </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        {% for hs in history %}
                        <tr class="table-row">
                            <td class="px-8 py-6">
                                <span class="text-sm font-bold">{{ hs.date.date }}</span>
                                <span class="block text-[10px] text-gray-500">{{ hs.date.time }}</span>
                            </td>
                            <td class="px-8 py-6">
                                <span class="text-xs font-mono text-gray-400">#{{ hs.id }}</span>
                            </td>
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-3">
                                    <span class="text-sm font-bold">{{ hs.reference }}</span>
                                </div>
                            </td>
                            <td class="px-8 py-6">
                                <span class="text-sm font-black italic">S/ {{ hs.amount }}</span>
                            </td>
                            <td class="px-8 py-6">
                                {% if hs.status == "accepted" %}
                                <span class="status-badge badge-active">
                                    <i class="fa-solid fa-circle text-[6px]"></i> Completado
                                </span>
                                {% elif hs.status == "pending" %}
                                <span class="status-badge badge-pending">
                                    <i class="fa-solid fa-circle text-[6px]"></i> Pendiente
                                </span>
                                {% else %}
                                <span class="status-badge badge-blocked">
                                    <i class="fa-solid fa-circle text-[6px]"></i> Rechazado
                                </span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="p-6 bg-white/1 flex items-center justify-between border-t border-white/5">
                <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Mostrando ultimas 15
                    transacciones</span>
            </div>
        </div>

        <div class="mt-8 flex items-start gap-4 p-6 rounded-3xl bg-(--accent)/5 border border-(--accent)/10">
            <i class="fa-solid fa-circle-info text-(--accent) mt-1"></i>
            <p class="text-xs text-gray-400 leading-relaxed">
                Las transacciones pueden tardar hasta 24 horas en aparecer en tu historial oficial. Si tienes algún
                problema con un cobro, por favor contacta a soporte técnico mencionando el <span
                    class="text-white font-bold">ID de Transacción</span>.
            </p>
        </div>

    </div>
</main>
{% include "components/dashboard-footer.njk" %}

{% endblock %}