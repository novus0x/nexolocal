{% extends "layouts/dashboard.njk" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}
<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        {% include "components/verify-account.njk" %}

        {% if companies_q == 0 %}
        <section class="mb-12">
            <div class="bg-(--accent-hover)/8 rounded-3xl p-8 md:p-12 relative overflow-hidden">
                <div class="relative z-10 max-w-2xl">
                    <div
                        class="inline-block px-3 py-1 mb-4 rounded-full bg-(--accent) text-white text-[10px] font-black uppercase tracking-widest">
                        OFERTA DE BIENVENIDA
                    </div>
                    <h2 class="text-4xl md:text-5xl nexo-black nexo uppercase leading-none mb-4">
                        COMIENZA TU <span class="text-orange-500">Prueba Gratuita</span>
                    </h2>
                    <p class="text-slate-300 text-sm mb-8 leading-relaxed">
                        Explora todas las herramientas de NexoLocal sin restricciones. Crea tu primera compañía,
                        configura tu plan y escala tu negocio hoy mismo.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="/dashboard/billing/plans"
                            class="mt-4 bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-4 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95 cursor-pointer">
                            Ver Planes Disponibles
                        </a>
                    </div>
                </div>
                <i
                    class="fa-solid fa-rocket absolute -right-10 -bottom-10 text-[20rem] text-orange-500/5 rotate-12"></i>
            </div>
        </section>
        {% else %}
        <section class="mb-12">
            <div class="bg-blue-500/8 rounded-3xl p-8 md:p-12 relative overflow-hidden">
                <div class="relative z-10 max-w-2xl">
                    <div
                        class="inline-block px-3 py-1 mb-4 rounded-full bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest">
                        SIGUIENTE NIVEL
                    </div>
                    <h2 class="text-4xl md:text-5xl nexo-black nexo uppercase leading-none mb-4">
                        POTENCIA TU <span class="text-blue-500">NEGOCIO</span>
                    </h2>
                    <p class="text-slate-300 text-sm mb-8 leading-relaxed">
                        Mejora tu plan según las necesidades de tu negocio.
                    </p>
                </div>
                <i
                    class="fa-solid fa-chart-line absolute -right-10 -bottom-10 text-[20rem] text-blue-500/5 rotate-12"></i>
            </div>
        </section>

        {% endif %}

        <section class="mb-12">
            <h3 class="text-xs font-bold text-slate-400 tracking-[0.08em] mb-6">Herramientas
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-2">

                <a href="/dashboard/support"
                    class="glass-card flex items-center justify-center min-h-24 px-4 py-6 rounded-2xl group">
                    <div
                        class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-headset text-lg"></i>
                    </div>
                    <span class="text-xs ml-3 font-semibold tracking-wide">Soporte</span>
                </a>

                <a href="/dashboard/support/tickets"
                    class="glass-card flex items-center justify-center min-h-24 px-4 py-6 rounded-2xl group">
                    <div
                        class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-500 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-ticket text-lg"></i>
                    </div>
                    <span class="text-xs ml-3 font-semibold tracking-wide">Mis tickets</span>
                </a>

                <a href="/dashboard/billing"
                    class="glass-card flex items-center justify-center min-h-24 px-4 py-6 rounded-2xl group">
                    <div
                        class="w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-credit-card text-lg"></i>
                    </div>
                    <span class="text-xs ml-3 font-semibold tracking-wide">Planes y pagos</span>
                </a>

                <a href="/users/settings"
                    class="glass-card flex items-center justify-center min-h-24 px-4 py-6 rounded-2xl group lg:flex">
                    <div
                        class="w-10 h-10 rounded-xl bg-slate-500/10 flex items-center justify-center text-slate-400 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-gear text-lg"></i>
                    </div>
                    <span class="text-xs ml-3 font-semibold tracking-wide">Ajustes</span>
                </a>

            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 glass-card rounded-3xl p-8">
                <div class="flex justify-between items-center mb-8">
                    <h3 class="text-lg font-semibold text-(--accent)">Tus compañías</h3>
                    <button class="text-xs font-semibold text-(--accent) hover:underline">Ver todas</button>
                </div>

                <div class="flex flex-col items-center justify-center py-12 text-center">
                    <div
                        class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-4 border border-white/10">
                        <i class="fa-solid fa-folder-open text-slate-600 text-2xl"></i>
                    </div>
                    <p class="text-slate-400 text-sm">No tienes compañías activas todavía.</p>
                    <p class="text-[10px] text-slate-600 mt-1 font-semibold tracking-wide">Activa un plan para
                        comenzar</p>
                </div>
            </div>

            <div class="space-y-6">
                <div class="glass-card rounded-3xl p-6">
                    <h4 class="text-xs font-semibold text-slate-400 tracking-wide mb-2">Próxima renovación
                    </h4>
                    <p class="text-xl font-bold">N/A</p>
                    <p class="text-xs text-slate-500 mt-2">No hay suscripciones activas vinculadas a este perfil.
                    </p>
                </div>
            </div>
        </div>

    </div>
</main>
{% include "components/dashboard-footer.njk" %}

{% endblock %}
