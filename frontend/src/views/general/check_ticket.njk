{% extends "layouts/main.njk" %}

{% block title %}Platform Dashboard{% endblock %}

{% block content %}

<style>
    :root {
        --color-nexo-orange: #FD420A;
        --color-nexo-dark-primary: #0B0F14;
        --color-nexo-dark-secondary: #0D1117;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--color-nexo-dark-primary);
        color: #ffffff;
        margin: 0;
        overflow-x: hidden;
    }

    .nexo-gradient-bg {
        background: radial-gradient(circle at 50% -20%, #fd420a22 0%, #0b0f14 60%);
    }

    .nexo-card {
        background-color: var(--color-nexo-dark-secondary);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .btn-primary {
        background-color: var(--color-nexo-orange);
        color: white;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        filter: brightness(1.1);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(253, 66, 10, 0.4);
    }

    .input-nexo {
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.2s ease;
    }

    .input-nexo:focus {
        border-color: var(--color-nexo-orange);
        background-color: rgba(255, 255, 255, 0.06);
        outline: none;
    }

    .text-nexo {
        color: var(--color-nexo-orange);
    }

    @media (min-width: 768px) {
        .search-form {
            flex-direction: row;
        }
    }

    /* Animaciones */
    .fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

{% if ticket %}
{% set display_company_name = ticket.company.legal_name or ticket.company.name %}
{% set display_invoice = ticket.sale.tax_document.invoice if ticket.sale.tax_document and ticket.sale.tax_document.invoice else ticket.sale.invoice %}
{% set display_client_name = ticket.sale.client_name or (ticket.sale.tax_document.customer_name if ticket.sale.tax_document else "CLIENTE VARIOS") or "CLIENTE VARIOS" %}
{% set display_client_doc = ticket.sale.client_doc_number or (ticket.sale.tax_document.customer_tax_id if ticket.sale.tax_document else "00000000") or "00000000" %}
{% set display_subtotal = ticket.sale.subtotal if ticket.sale.subtotal is not none else (ticket.sale.total - ticket.sale.tax) %}
{% set display_taxable = ticket.sale.taxable_amount if ticket.sale.taxable_amount is not none else display_subtotal %}
{% endif %}

<div class="nexo-gradient-bg min-h-screen">

    <header class="p-8 flex justify-center">
        <a href="/" class="flex items-center gap-2">
            <img src="/public/img/logo.svg" class="w-10 h-10">
            <span class="text-xl font-extrabold tracking-tighter">Nexolocal</span>
        </a>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">

        <div class="text-center mb-16 fade-in">
            <h1 class="text-5xl md:text-6xl font-extrabold mb-6 tracking-tight">
                Tus facturas, <span class="text-nexo">al instante.</span>
            </h1>
            <p class="text-gray-400 text-lg max-w-xl mx-auto leading-relaxed">
                Ingresa los detalles de tu ticket para descargar tu comprobante electrónico de forma segura.
            </p>
        </div>

        <div class="max-w-2xl mx-auto mb-16 fade-in" style="animation-delay: 0.1s;">
            <form method="get" action="/check-ticket" class="nexo-card p-2 flex justify-between flex-col md:flex-row gap-0.5">
                <div class="glow flex items-center px-4 py-2">
                    <i class="fa-solid fa-magnifying-glass text-gray-500 mr-3"></i>
                    <input type="text" name="q" value="{{ query or '' }}"
                        placeholder="Número de Ticket o Serie (Ej: B001-000123)"
                        class="bg-transparent w-full text-white placeholder-gray-600 focus:outline-none font-medium">
                </div>
                <button type="submit" class="btn-primary px-8 py-4 rounded-xl font-bold text-sm uppercase tracking-wider cursor-pointer">
                    Consultar
                </button>
            </form>
        </div>

        {% if ticket %}
        <div class="grid md:grid-cols-1 gap-8 fade-in" style="animation-delay: 0.2s;">
            <div class="nexo-card overflow-hidden">
                <div class="p-8 border-b border-white/5 flex flex-wrap justify-between items-center gap-4">
                    <div>
                        <p class="text-xs font-bold text-nexo uppercase tracking-widest mb-1">Resultado de búsqueda</p>
                        <h2 class="text-2xl font-bold">{{ display_invoice }}</h2>
                    </div>
                    <div class="status-pill px-4 py-1 rounded-full text-xs font-bold uppercase text-green-300 border border-green-500/20 bg-green-500/10">
                        {{ ticket.sale.tax_document.status if ticket.sale.tax_document and ticket.sale.tax_document.status else "Disponible" }}
                    </div>
                </div>

                <div class="p-8 grid md:grid-cols-3 gap-8">
                    <div>
                        <span class="block text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-3">Emisor</span>
                        <p class="font-bold text-white">{{ display_company_name }}</p>
                        {% if ticket.company.tax_id %}
                        <p class="text-sm text-gray-500 mt-1">RUC: {{ ticket.company.tax_id }}</p>
                        {% endif %}
                    </div>

                    <div>
                        <span class="block text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-3">Cliente</span>
                        <p class="font-bold text-white">{{ display_client_name }}</p>
                        <p class="text-sm text-gray-500 mt-1">{{ display_client_doc }}</p>
                    </div>

                    <div class="bg-black/20 p-4 rounded-2xl border border-white/5">
                        <span class="block text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-2">Total</span>
                        <p class="text-3xl font-extrabold text-white">S/ {{ ticket.sale.total | round(2) }}</p>
                    </div>
                </div>

                <div class="px-8 pb-8 grid md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Fecha y moneda</p>
                        <p class="text-white font-bold">{{ ticket.sale.date }}</p>
                        <p class="text-sm text-gray-500">{{ ticket.sale.currency or "PEN" }}</p>
                    </div>
                    <div class="space-y-2">
                        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Resumen</p>
                        <p class="text-sm text-gray-300">Subtotal: S/ {{ display_subtotal | round(2) }}</p>
                        <p class="text-sm text-gray-300">Op. Gravada: S/ {{ display_taxable | round(2) }}</p>
                        <p class="text-sm text-gray-300">IGV: S/ {{ ticket.sale.tax | round(2) }}</p>
                    </div>
                </div>

                <div class="px-8 pb-8">
                    <div class="overflow-hidden rounded-2xl border border-white/5">
                        <table class="w-full text-sm">
                            <thead class="bg-white/5 text-gray-400 uppercase text-[10px] tracking-widest">
                                <tr>
                                    <th class="text-left px-4 py-3">Descripcion</th>
                                    <th class="text-center px-4 py-3">Cant</th>
                                    <th class="text-right px-4 py-3">P. Unit</th>
                                    <th class="text-right px-4 py-3">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in ticket.sale.items %}
                                <tr class="border-t border-white/5">
                                    <td class="px-4 py-3 text-white">{{ item.name }}</td>
                                    <td class="px-4 py-3 text-center text-gray-300">
                                        {% if item.is_bulk %}{{ item.quantity | round(3) }}{% else %}{{ item.quantity }}{% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-right text-gray-300">S/ {{ item.price | round(2) }}</td>
                                    <td class="px-4 py-3 text-right text-white font-bold">S/ {{ item.total | round(2) }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-white/2 p-6 flex flex-wrap gap-4 justify-center md:justify-start">
                    {% if ticket.sale.tax_document and ticket.sale.tax_document.has_xml %}
                    <span class="flex items-center gap-2 bg-white/5 px-6 py-3 rounded-xl border border-white/10">
                        <span class="text-sm font-bold">XML disponible</span>
                    </span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% elif error_message %}
        <div class="grid md:grid-cols-1 gap-8 fade-in" style="animation-delay: 0.2s;">
            <div class="nexo-card overflow-hidden">
                <div class="p-8 border-b border-white/5">
                    <p class="text-xs font-bold text-nexo uppercase tracking-widest mb-1">Resultado de búsqueda</p>
                    <h2 class="text-2xl font-bold">{{ query }}</h2>
                </div>
                <div class="p-8">
                    <p class="text-white font-bold">{{ error_message }}</p>
                </div>
            </div>
        </div>
        {% endif %}
    </main>

    <footer class="mt-20 py-10 border-t border-white/5 text-center">
        <p class="text-gray-600 text-[10px] font-bold uppercase tracking-[0.4em]">Nexolocal Tecnología Tributaria</p>
    </footer>

</div>

{% endblock %}
