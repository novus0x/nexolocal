{% extends "layouts/dashboard.njk" %}

{% block title %}Platform Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}
<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        <div class="mb-8">
            <nav class="flex mb-3 text-xs font-bold tracking-widest text-gray-500 flex-col md:flex-row gap-5"
                aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 uppercase">
                    <li class="inline-flex items-center">
                        <a href="/companies/{{ company_information.id }}"
                            class="hover:text-white transition-colors">Negocio</a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <a href="/companies/{{ company_information.id }}/products" id="breadcrumb-workspace"
                                class="hover:text-white ml-1 md:ml-2 transition-colors">Productos</a>
                        </div>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <a href="/companies/{{ company_information.id }}/products/read/{{ product.id }}"
                                id="breadcrumb-workspace" class="hover:text-white ml-1 md:ml-2 transition-colors">{{
                                product.name }}</a>
                        </div>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <a href="/companies/{{ company_information.id }}/products/{{ product.id }}/batchs"
                                id="breadcrumb-workspace"
                                class="hover:text-white ml-1 md:ml-2 transition-colors">Batchs</a>
                        </div>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <span class="ml-1 md:ml-2 text-orange-500">Nuevo</span>
                        </div>
                    </li>
                </ol>
            </nav>
        </div>

        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Registro de Nuevo Lote</h1>
            <p class="text-gray-500 mt-1">Ingresa los detalles de entrada para actualizar el stock global.</p>
        </div>

        <div class="grid col-span-1 md:grid-cols-2 gap-8">
            <div class="col-span-1 md:col-span-1 space-y-8">
                <div class="glass-card rounded-3xl p-6 md:p-10 shadow-2xl relative overflow-hidden">
                    <form class="space-y-8"
                        action="/companies/{{ company_information.id }}/products/{{ product.id }}/batchs/create"
                        method="post">
                        <div class="grid grid-cols-1 md:grid-cols-1 gap-6">
                            {# <div class="space-y-2">
                                <label
                                    class="text-xs font-bold uppercase tracking-widest text-slate-500 ml-1">Producto</label>
                                <div class="relative group">
                                    <i
                                        class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 group-focus-within:text-brand transition-colors"></i>
                                    <input type="text" placeholder="Buscar por nombre o SKU..."
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all">
                                </div>
                            </div> #}
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500 ml-1">Cantidad
                                    de Ingreso</label>
                                <input type="number" id="qty" placeholder="0" step="0.001" min="0" name="quantity"
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-4 text-white focus:outline-none focus:border-brand transition-all text-xl font-bold"
                                    value="{{ quantity }}" required>
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="text-xs font-bold uppercase tracking-widest text-slate-500 ml-1">Bonificación
                                    de Productos</label>
                                <input type="number" id="bonus" placeholder="0" name="bonus" step="0.001" min="0"
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-4 text-white focus:outline-none focus:border-brand transition-all text-xl font-bold"
                                    value="{{ bonus or 0 }}">
                                <p class="text-xs text-gray-500">Productos otorgados como un extra por el provedor (no
                                    seran contabilizados como costo)</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500 ml-1">Fecha de
                                    Recepción</label>
                                <input type="date" name="reception_date"
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-white focus:outline-none focus:border-brand transition-all"
                                    value="{{ today_inp }}">
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="text-xs font-bold uppercase tracking-widest text-slate-500 ml-1">Vencimiento</label>
                                <input type="date" name="expiration_date"
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-white focus:outline-none focus:border-brand transition-all"
                                    value="{{ expiration_date }}">
                            </div>
                        </div>

                        <div
                            class="bg-white/5 rounded-2xl p-6 grid grid-cols-1 md:grid-cols-2 gap-8 border border-white/5">
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-400">Precio de
                                    venta</label>
                                <div class="relative">
                                    <span
                                        class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 font-bold">S/</span>
                                    <input type="number" id="price" step="0.01" placeholder="0.00" name="price"
                                        class="w-full bg-transparent border-b border-white/20 py-3 pl-10 pr-4 text-white focus:outline-none focus:border-brand text-2xl font-medium transition-all"
                                        value="{{ price or product.price }}">
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-400">Costo de
                                    Compra</label>
                                <div class="relative">
                                    <span
                                        class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 font-bold">S/</span>
                                    <input type="number" id="cost" step="0.01" placeholder="0.00" name="cost"
                                        class="w-full bg-transparent border-b border-white/20 py-3 pl-10 pr-4 text-white focus:outline-none focus:border-brand text-2xl font-medium transition-all"
                                        value="{{ cost or product.cost }}">
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between pt-4">
                            <a href="/companies/{{ company_information.id }}/products/read/{{ product.id }}"
                                class="text-sm font-semibold text-red-500 hover:text-red-700 transition-colors">Cancelar</a>
                            <button type="submit"
                                class="bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95 cursor-pointer">
                                <i class="fa-solid fa-plus"></i>
                                Crear Lote
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <aside class="w-full space-y-6 col-span-1 md:col-span-1">
                <div class="glass-card rounded-3xl p-6 space-y-6">
                    <h3 class="text-sm font-bold text-white flex items-center gap-2 italic uppercase tracking-tighter">
                        <span class="w-2 h-2 bg-brand rounded-full animate-pulse"></span>
                        Insights en Tiempo Real
                    </h3>

                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <span class="text-slate-400 text-xs font-medium">Inversión Total</span>
                            <span id="total-inv" class="text-lg font-bold text-red-400 leading-none">S/0</span>
                        </div>
                        <div class="flex justify-between items-end">
                            <span class="text-slate-400 text-xs font-medium">Ganancia Est. - Stock</span>
                            <span id="total-stock" class="text-lg font-bold text-emerald-400 leading-none">S/0</span>
                        </div>
                        <div class="flex justify-between items-end">
                            <span class="text-slate-400 text-xs font-medium">Ganancia Est. - Bonificación</span>
                            <span id="total-bonus" class="text-lg font-bold text-emerald-400 leading-none">S/0</span>
                        </div>
                        <hr class="border-white/5" />
                        <div class="flex justify-between items-end">
                            <span class="text-slate-400 text-xs font-medium">Ganancia Est. Total</span>
                            <span id="total-profit" class="text-lg font-bold text-emerald-400 leading-none">S/0</span>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

    </div>
</main>

<script>
    const qty = document.getElementById("qty");
    const price = document.getElementById("price");
    const cost = document.getElementById("cost");
    const bonus = document.getElementById("bonus");

    const total_inv = document.getElementById("total-inv");
    const total_stock = document.getElementById("total-stock");
    const total_bonus = document.getElementById("total-bonus");
    const total_profit = document.getElementById("total-profit");

    function update_insights() {
        const qtyValue = Number.parseFloat(qty.value) || 0;
        const priceValue = Number.parseFloat(price.value) || 0;
        const costValue = Number.parseFloat(cost.value) || 0;
        const bonusValue = Number.parseFloat(bonus.value) || 0;

        const inv = qtyValue * costValue;
        const to_stock = qtyValue * priceValue - inv;
        const to_bonus = bonusValue * priceValue;
        const to = to_stock + to_bonus;

        total_inv.textContent = `S/${inv}`;
        total_stock.textContent = `S/${to_stock}`;
        total_bonus.textContent = `S/${to_bonus}`;
        total_profit.textContent = `S/${to}`;
    };

    [qty, price, cost, bonus].forEach((input) => {
        input.addEventListener("input", update_insights);
    });

    update_insights();
</script>

{% include "components/dashboard-footer.njk" %}

{% endblock %}