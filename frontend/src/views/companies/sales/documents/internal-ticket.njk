<style>
    body {
        margin: 0 auto;
        padding: 5mm;
        background: #fff;
        color: #000;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 11px;
    }

    .dotted-line {
        border-top: 1px dotted #000;
        margin: 5px 0;
    }

    .text-center {
        text-align: center;
    }

    .bold {
        font-weight: bold;
    }

    .w-full {
        width: 100%;
    }

    .qr-placeholder {
        width: 100px;
        height: 100px;
        border: 1px solid #000;
        margin: 10px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 8px;
    }
</style>

{% set display_company_name = company.legal_name or company.name %}
{% set display_tax_id = company.tax_id %}
{% set has_reported_tax_document = sale.tax_document and company.tax_environment != "sandbox" %}
{% set sale_series_correlativo = sale.series ~ "-" ~ sale.correlativo if sale.series and sale.correlativo else "" %}
{% set display_invoice = sale.internal_invoice or sale.invoice %}
{% set display_fiscal_invoice = sale_series_correlativo or (sale.tax_document.invoice if has_reported_tax_document and sale.tax_document.invoice else "") %}
{% set display_client_name = sale.client_name or (sale.tax_document.customer_name if sale.tax_document else "CLIENTE VARIOS") or "CLIENTE VARIOS" %}
{% set display_client_doc = sale.client_doc_number or (sale.tax_document.customer_tax_id if sale.tax_document else "00000000") or "00000000" %}
{% set sale_subtotal = sale.subtotal if sale.subtotal is not none else (sale.total - sale.tax) %}
{% set sale_taxable = sale.taxable_amount if sale.taxable_amount is not none else sale_subtotal %}
{% set public_query = public_query if public_query else (sale.internal_invoice or sale.invoice) %}
{% set show_fiscal_data = company.is_formal and company.fiscal_address %}

<div class="text-center">
    <div class="bold" style="font-size: 14px;">{{ display_company_name }}</div>
    {% if show_fiscal_data and display_tax_id %}
    <div>RUC: {{ display_tax_id }}</div>
    {% endif %}
    {% if show_fiscal_data %}
    <div>Dir. Fiscal: {{ company.fiscal_address }}</div>
    {% else %}
    <div>{{ company.address }}</div>
    {% endif %}
    {% if company.phone %}
    <div>Telf: {{ company.phone }}</div>
    {% endif %}
</div>

<div class="dotted-line"></div>

<div class="text-center bold" style="font-size: 12px;">
    BOLETA DE VENTA ELECTRÓNICA
</div>
{% if display_fiscal_invoice %}
<div class="text-center bold">
    {{ display_fiscal_invoice }}
</div>
{% endif %}
<div class="text-center bold">
    {{ display_invoice }}
</div>

<div class="dotted-line"></div>

<table class="w-full">
    <tr>
        <td>Fecha Emisión:</td>
        <td align="right">{{ sale.issue_date or sale.date }}</td>
    </tr>
    <tr>
        <td>Cliente:</td>
        <td align="right">{{ display_client_name }}</td>
    </tr>
    <tr>
        <td>DNI/RUC:</td>
        <td align="right">{{ display_client_doc }}</td>
    </tr>
    <tr>
        <td>Moneda:</td>
        <td align="right">{{ sale.currency or "PEN" }}{% if (sale.currency or "PEN") == "PEN" %} - SOLES (S/){% endif %}</td>
    </tr>
    {% if display_fiscal_invoice %}
    <tr>
        <td>Serie - Correlativo:</td>
        <td align="right">{{ display_fiscal_invoice }}</td>
    </tr>
    {% endif %}
</table>

<div class="dotted-line"></div>

<table class="w-full">
    <thead>
        <tr>
            <th align="left">DESCRIPCIÓN</th>
            <th align="center">CANT</th>
            <th align="right">P. UNIT</th>
            <th align="right">TOTAL</th>
        </tr>
    </thead>
    <tbody>
        {% for item in sale.items %}
        <tr>
            <td colspan="4" style="padding-top: 5px;">{{ item.name }}</td>
        </tr>
        <tr>
            <td align="left" style="font-size: 10px;">
                {% if item.is_service %}
                SERVICIO
                {% elif item.is_bulk %}
                A GRANEL
                {% else %}
                PRODUCTO
                {% endif %}
            </td>

            <td align="center">
                {% if item.is_bulk %}
                {{ item.quantity | round(3) }}
                {% else %}
                {{ item.quantity }}
                {% endif %}
            </td>

            <td align="right">
                S/ {{ item.price | round(2) }}
            </td>

            <td align="right">
                S/ {{ item.total | round(2) }}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<div class="dotted-line"></div>

<table class="w-full">
    <tr>
        <td>Subtotal:</td>
        <td align="right">S/ {{ sale_subtotal | round(2) }}</td>
    </tr>
    {% if company.is_formal %}
    <tr>
        <td>Op. Gravada:</td>
        <td align="right">S/ {{ sale_taxable | round(2) }}</td>
    </tr>
    {% endif %}
    {% if company.is_formal and sale.tax > 0 %}
    <tr>
        <td>IGV (18%):</td>
        <td align="right">S/ {{ sale.tax | round(2) }}</td>
    </tr>
    {% endif %}
    <tr>
        <td class="bold" style="font-size: 14px;">TOTAL:</td>
        <td align="right" class="bold" style="font-size: 14px;">S/ {{ sale.total }}</td>
    </tr>
</table>

<div class="dotted-line"></div>

<div style="font-size: 10px; margin-bottom: 5px;">
    SON: {{ string_value }}
</div>

<div class="dotted-line"></div>

<div class="text-center">
    <div class="qr-placeholder">
        {{ qrcode | safe }}
    </div>
    <div style="font-size: 9px;">
        Boleta de Venta Electrónica.<br>
        Consulte su documento en:<br>
        <span class="bold">nexolocal.floua.app/check-ticket?q={{ public_query }}</span>
    </div>
    <br>
    <div class="bold">¡GRACIAS POR SU COMPRA!</div>
</div>
