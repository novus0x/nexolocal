<script>
    function switch_tab(tab_id) {
        const contents = document.querySelectorAll('.tab-content');
        const buttons = document.querySelectorAll('.tab-btn');
        const nav_links = document.querySelectorAll('.nav-link');

        contents.forEach(content => content.classList.remove('active'));

        buttons.forEach(btn => {
            btn.classList.remove('bg-[#10141B]', 'border-[#262D38]', 'shadow-2xl', 'scale-[1.02]');
            btn.classList.add('bg-transparent', 'border-transparent');

            const iconBox = btn.querySelector('.icon-box');
            iconBox.classList.remove('bg-[#FF4D00]', 'text-white', 'rotate-6');
            iconBox.classList.add('bg-[#10141B]', 'text-gray-600');

            const title = btn.querySelector('.tab-title');
            title.classList.remove('text-white');
            title.classList.add('text-gray-600');
        });

        nav_links.forEach(link => {
            link.classList.remove('text-[#FF4D00]');
            link.classList.add('text-gray-500');
        });

        const active_content = document.getElementById(`view-${tab_id}`);
        const active_btn = document.getElementById(`btn-${tab_id}`);
        const active_nav_link = document.querySelector(`.nav-link[data-target="${tab_id}"]`);

        if (active_content) active_content.classList.add('active');

        if (active_btn) {
            active_btn.classList.add('bg-[#10141B]', 'border-[#262D38]', 'shadow-2xl', 'scale-[1.02]');
            active_btn.classList.remove('bg-transparent', 'border-transparent');

            const iconBox = active_btn.querySelector('.icon-box');
            iconBox.classList.add('bg-[#FF4D00]', 'text-white', 'rotate-6');
            iconBox.classList.remove('bg-[#10141B]', 'text-gray-600');

            const title = active_btn.querySelector('.tab-title');
            title.classList.add('text-white');
            title.classList.remove('text-gray-600');
        }

        if (active_nav_link) {
            active_nav_link.classList.add('text-[#FF4D00]');
            active_nav_link.classList.remove('text-gray-500');
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        switch_tab('identity');

        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                const target = e.target.getAttribute('data-target');
                switch_tab(target);
            });
        });

    });
</script>

