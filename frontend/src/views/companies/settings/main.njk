{% extends "layouts/dashboard.njk" %}

{% block title %}Platform Dashboard{% endblock %}

{% block content %}
{% include "components/dashboard-sidebar.njk" %}
{% include "components/dashboard-header.njk" %}

<main class="flex-1 overflow-y-auto p-6 lg:p-10">
    <div class="w-full space-y-8">

        <div class="mb-8">
            <nav class="flex mb-3 text-xs font-bold tracking-widest text-gray-500 justify-between flex-col md:flex-row gap-5"
                aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 uppercase">
                    <li class="inline-flex items-center">
                        <a href="/companies/{{ company_information.id }}"
                            class="hover:text-white transition-colors">Negocio</a>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <i class="fa-solid fa-chevron-right text-gray-600"></i>
                            <span class="ml-1 md:ml-2 text-orange-500">Configuración</span>
                        </div>
                    </li>
                </ol>
            </nav>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
            <button onclick="switch_tab('identity')" id="btn-identity"
                class="tab-btn relative overflow-hidden p-6 rounded-4xl transition-all duration-500 border-2 text-left">
                <div
                    class="icon-box w-12 h-12 rounded-2xl flex items-center justify-center mb-4 transition-all duration-500 bg-[#10141B] text-gray-600">
                    <i class="fa-solid fa-info text-xl"></i>
                </div>
                <h3 class="tab-title text-sm font-black uppercase tracking-widest text-gray-600">Información</h3>
                <p class="text-[9px] font-bold text-gray-700 uppercase mt-1">sobre la empresa</p>
            </button>

            {# <button onclick="switch_tab('network')" id="btn-network"
                class="tab-btn relative overflow-hidden p-6 rounded-4xl transition-all duration-500 border-2 text-left">
                <div
                    class="icon-box w-12 h-12 rounded-2xl flex items-center justify-center mb-4 transition-all duration-500 bg-[#10141B] text-gray-600">
                    <i data-lucide="globe"></i>
                </div>
                <h3 class="tab-title text-sm font-black uppercase tracking-widest text-gray-600">Red</h3>
                <p class="text-[9px] font-bold text-gray-700 uppercase mt-1">Infraestructura</p>
            </button>

            <button onclick="switch_tab('security')" id="btn-security"
                class="tab-btn relative overflow-hidden p-6 rounded-4xl transition-all duration-500 border-2 text-left">
                <div
                    class="icon-box w-12 h-12 rounded-2xl flex items-center justify-center mb-4 transition-all duration-500 bg-[#10141B] text-gray-600">
                    <i data-lucide="shield"></i>
                </div>
                <h3 class="tab-title text-sm font-black uppercase tracking-widest text-gray-600">Seguridad</h3>
                <p class="text-[9px] font-bold text-gray-700 uppercase mt-1">Protocolos</p>
            </button>

            <button onclick="switch_tab('social')" id="btn-social"
                class="tab-btn relative overflow-hidden p-6 rounded-4xl transition-all duration-500 border-2 text-left">
                <div
                    class="icon-box w-12 h-12 rounded-2xl flex items-center justify-center mb-4 transition-all duration-500 bg-[#10141B] text-gray-600">
                    <i data-lucide="share-2"></i>
                </div>
                <h3 class="tab-title text-sm font-black uppercase tracking-widest text-gray-600">Ecosistema</h3>
                <p class="text-[9px] font-bold text-gray-700 uppercase mt-1">Comunidad</p>
            </button> #}
        </div>

        <div class="relative">
            <div class="relative z-10">
                <div id="view-identity" class="tab-content active space-y-8">
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                        <div class="space-y-2">
                            <h1 class="text-4xl font-black italic uppercase tracking-tighter leading-[0.9]">
                                <span class="text-outline-white">Panel</span> de <span class="text-[#FF4D00]"
                                    id="display-tab-name">Configuración</span>
                            </h1>
                        </div>
                    </div>

                    <form class="grid grid-cols-12 gap-8" action="/companies/{{ company_information.id }}/settings" enctype="multipart/form-data" method="post" >
                        <div class="col-span-12 lg:col-span-8 space-y-8">

                            <section class="glass-card rounded-[2.5rem] p-10 relative overflow-hidden">
                                <div class="flex justify-between items-start mb-6 relative z-10">
                                    <div>
                                        <h2 class="text-2xl font-black uppercase italic">Configuración del Negocio
                                        </h2>
                                    </div>
                                    <div class="flex gap-2">
                                        {% if company.active %}
                                        <span class="badge badge-active">Activo</span>
                                        {% else %}
                                        <span class="badge badge-pending">Require Ser Activado</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                                    <div class="space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Nombre
                                            Comercial</label>
                                        <input type="text" value="{{ company.name }}" name="commercial_name"
                                            class="w-full input-glass px-5 py-4 rounded-xl font-bold text-sm">
                                    </div>
                                    <div class="space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Código de
                                            Identificación</label>
                                        <input type="text" value="{{ company.id }}"
                                            class="w-full input-glass px-5 py-4 rounded-xl font-mono text-xs accent-orange italic"
                                            disabled>
                                    </div>
                                    <div class="space-y-1 md:col-span-2">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Descripción de
                                            Actividad</label>
                                        <textarea rows="2" name="description"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm italic font-medium">{{ company.description }}</textarea>
                                    </div>
                                    <div class="space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Email
                                            Corporativo</label>
                                        <input type="email" value="{{ company.email }}" name="email"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm font-bold">
                                    </div>
                                    <div class="space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Teléfono de
                                            Contacto</label>
                                        <input type="text" value="{{ company.phone }}" name="phone"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm font-bold">
                                    </div>
                                </div>
                            </section>

                            <section class="glass-card rounded-4xl p-8 border-dashed border-2 border-gray-800">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-4">
                                        <div class="bg-white/5 p-3 rounded-xl">
                                            <i class="fa-regular fa-file-lines text-xl"></i>
                                        </div>
                                        <div>
                                            <h3 class="text-lg font-black italic uppercase">Activa el Perfil Fiscal y
                                                Facturación</h3>
                                            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">
                                                Una vez activado no se puede desactivar, sin embargo una vez creado
                                                luego puede decidir si desea que la emisión sea automática o manual.
                                            </p>
                                        </div>
                                    </div>

                                    <label class="nexo-switch">
                                        <input type="checkbox" name="is_formal" onchange="activate_taxes(this.checked)">
                                        <div class="bg"></div>
                                        <div class="dot"></div>
                                    </label>
                                </div>
                            </section>

                            {% if not company.is_formal %}
                            <section class="glass-card rounded-[2.5rem] p-10 hidden" id="creation_tax_profile">
                                <div class="flex items-center gap-4 mb-10">
                                    <div>
                                        <h2 class="text-2xl font-black italic uppercase">Perfil Fiscal</h2>
                                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mt-1">
                                            Configuración de Emisor Electrónico</p>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                                    <div class="md:col-span-8 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Razón
                                            Social</label>
                                        <input type="text" name="legal_name"
                                            class="w-full input-glass px-5 py-4 rounded-xl font-bold text-sm uppercase">
                                    </div>
                                    <div class="md:col-span-4 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Identificación
                                            Fiscal (ID)</label>
                                        <input type="text" name="tax_id"
                                            class="w-full input-glass px-5 py-4 rounded-xl font-mono text-sm tracking-widest">
                                    </div>
                                    <div class="md:col-span-6 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Dirección
                                            Fiscal</label>
                                        <input type="text" name="address_line"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm">
                                    </div>
                                    <div class="md:col-span-2 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Región</label>
                                        <input type="text" name="region"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm">
                                    </div>
                                    <div class="md:col-span-2 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Ciudad</label>
                                        <input type="text" name="city"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm">
                                    </div>
                                    <div class="md:col-span-2 space-y-1">
                                        <label class="text-[9px] font-black uppercase text-gray-500 ml-2">Código
                                            Postal</label>
                                        <input type="text" name="postal_code"
                                            class="w-full input-glass px-5 py-4 rounded-xl text-sm">
                                    </div>
                                    <div class="md:col-span-12">
                                        <div class="mb-4">

                                            <h2 class="text-sm font-black uppercase text-(--accent)">
                                                Credenciales de Facturación Electrónica
                                            </h2>
                                            <p class="text-xs text-gray-500 mt-1">
                                                Estas credenciales permiten emitir comprobantes electrónicos de forma
                                                segura desde la plataforma.
                                            </p>
                                        </div>
                                        <div class="grid md:grid-cols-12 gap-4">
                                            <div class="md:col-span-6 space-y-1">
                                                <label class="text-[9px] font-black uppercase text-gray-500 ml-2">
                                                    Usuario
                                                </label>
                                                <input type="text" name="tax_user"
                                                    class="w-full input-glass px-5 py-4 rounded-xl font-bold text-sm">
                                                <p class="text-[10px] text-gray-500 ml-2 flex items-center gap-1">
                                                    <i class="fa-solid fa-circle-info text-(--accent)"></i>
                                                    Usuario proporcionado por tu proveedor de facturación.
                                                    <a href="#" class="text-(--accent) hover:underline ml-1 font-bold">
                                                        Ver ayuda
                                                    </a>
                                                </p>
                                            </div>
                                            <div class="md:col-span-6 space-y-1">
                                                <label class="text-[9px] font-black uppercase text-gray-500 ml-2">
                                                    Contraseña
                                                </label>
                                                <input type="password" name="tax_password"
                                                    class="w-full input-glass px-5 py-4 rounded-xl font-bold text-sm">
                                                <p class="text-[10px] text-gray-500 ml-2 flex items-center gap-1">
                                                    <i class="fa-solid fa-circle-info text-(--accent)"></i>
                                                    Contraseña asociada a tu usuario.
                                                    <a href="#" class="text-(--accent) hover:underline ml-1 font-bold">
                                                        Ver ayuda
                                                    </a>
                                                </p>
                                            </div>
                                            <div class="md:col-span-12 space-y-1">
                                                <label class="text-[9px] font-black uppercase text-gray-500 ml-2">
                                                    Certificado Digital
                                                </label>
                                                <input type="file" name="file" accept=".pem,.crt,.cer"
                                                    class="w-full input-glass px-5 py-4 rounded-xl font-bold text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-(--accent) file:text-black hover:file:bg-(--accent-hover)">
                                                <p class="text-[10px] text-gray-500 ml-2 flex items-center gap-1">
                                                    <i class="fa-solid fa-circle-info text-(--accent)"></i>
                                                    Archivo necesario para firmar electrónicamente tus comprobantes.
                                                    <a href="#" class="text-(--accent) hover:underline ml-1 font-bold">
                                                        Ver ayuda
                                                    </a>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>
                            {% else %}
                            {% endif %}
                        </div>

                        <div class="col-span-12 lg:col-span-4 space-y-8">
                            {% if plan.available %}
                            <section class="bg-(--accent) p-10 rounded-[2.5rem] relative overflow-hidden group">
                                <div
                                    class="absolute -right-4 -top-4 opacity-10 group-hover:rotate-12 transition-transform duration-700">
                                    <i data-lucide="crown" class="w-40 h-40"></i>
                                </div>

                                <div class="relative z-10">
                                    <div class="flex justify-between items-center mb-6">
                                        <span
                                            class="text-[10px] font-black uppercase border-2 border-black/20 px-4 py-1.5 rounded-full italic">Plan
                                            Actual</span>
                                        <span
                                            class="text-[10px] font-black uppercase bg-black text-white px-3 py-1 rounded-md">YEARLY</span>
                                    </div>
                                    <h3 class="text-4xl font-black italic uppercase leading-none mb-2">Plan
                                        Enterprise</h3>

                                    <div class="bg-black/10 p-6 rounded-3xl border border-black/5 mb-8">
                                        <p class="text-5xl font-black italic tracking-tighter mb-1">S/ 249.00<span
                                                class="text-lg opacity-60">/año</span></p>
                                        <p class="text-[10px] font-black uppercase opacity-60 italic">Facturación
                                            recurrente activada</p>
                                    </div>

                                    {# <button
                                        class=" bg-white hover:bg-gray-100 text-black px-6 py-3 rounded-2xl text-xl font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95 cursor-pointer w-full">
                                        Mejorar Plan
                                    </button> #}
                                </div>
                            </section>
                            {% endif %}

                            {% if not company.is_formal %}
                            <section class="hidden glass-card rounded-[3rem] p-10" id="tax_profile_series_container">
                                <div class="mb-6">
                                    <h3 class="text-xl font-black italic uppercase">
                                        Series de Comprobantes
                                    </h3>
                                    <p class="text-[10px] text-gray-500 mt-1 flex items-center gap-1">
                                        <i class="fa-solid fa-circle-info text-(--accent)"></i>
                                        Define la serie y el número inicial para tus comprobantes.
                                        <a href="#" class="text-(--accent) hover:underline font-bold ml-1">
                                            Ver ayuda
                                        </a>
                                    </p>
                                </div>

                                <div class="grid md:grid-cols-12 gap-6">
                                    <div class="md:col-span-6 space-y-3">
                                        <label class="text-[10px] font-black uppercase text-gray-500">
                                            Factura
                                        </label>
                                        <div class="space-y-1">
                                            <label class="text-[9px] text-gray-600 uppercase ml-2">
                                                Serie
                                            </label>
                                            <input name="invoice_series" placeholder="F001" maxlength="4"
                                                class="w-full input-glass px-5 py-4 rounded-xl font-black text-lg tracking-widest uppercase">
                                        </div>
                                        <div class="space-y-1">
                                            <label class="text-[9px] text-gray-600 uppercase ml-2">
                                                Número Actual
                                            </label>
                                            <input type="number" name="invoice_number" placeholder="0" min="0"
                                                class="w-full input-glass px-5 py-4 rounded-xl font-bold text-lg font-mono">
                                        </div>
                                    </div>
                                    <div class="md:col-span-6 space-y-3">
                                        <label class="text-[10px] font-black uppercase text-gray-500">
                                            Boleta
                                        </label>
                                        <div class="space-y-1">
                                            <label class="text-[9px] text-gray-600 uppercase ml-2">
                                                Serie
                                            </label>
                                            <input name="receipt_series" placeholder="B001" maxlength="4"
                                                class="w-full input-glass px-5 py-4 rounded-xl font-black text-lg tracking-widest uppercase">
                                        </div>
                                        <div class="space-y-1">
                                            <label class="text-[9px] text-gray-600 uppercase ml-2">
                                                Número Actual
                                            </label>
                                            <input type="number" name="receipt_number" placeholder="0" min="0"
                                                class="w-full input-glass px-5 py-4 rounded-xl font-bold text-lg font-mono">
                                        </div>
                                    </div>
                                </div>
                            </section>
                            {% else %}
                            <section class="glass-card rounded-[3rem] p-10 overflow-hidden relative">
                                <div class="flex items-center justify-between mb-8">
                                    <h3 class="text-xl font-black italic uppercase">Series Fiscales</h3>
                                    <button class="p-2 bg-white/5 rounded-xl hover:bg-white/10 transition-colors">
                                        <i data-lucide="plus" class="w-5 h-5"></i>
                                    </button>
                                </div>

                                <div class="space-y-4">
                                    <!-- SERIE 01 -->
                                    <div
                                        class="bg-[#050608] border border-[#1A1F26] p-6 rounded-2xl flex justify-between items-center group hover:border-[#FF4D00]/50 transition-colors">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <span
                                                    class="text-[9px] font-black text-gray-500 uppercase italic">Factura
                                                    (01)</span>
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                            </div>
                                            <p class="text-2xl font-black italic text-(--accent)">F001</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-[9px] font-black text-gray-600 uppercase mb-1">Correlativo
                                            </p>
                                            <p class="text-xl font-black font-mono">00001248</p>
                                        </div>
                                    </div>

                                    <!-- SERIE 03 -->
                                    <div
                                        class="bg-[#050608] border border-[#1A1F26] p-6 rounded-2xl flex justify-between items-center group hover:border-[#FF4D00]/50 transition-colors">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <span
                                                    class="text-[9px] font-black text-gray-500 uppercase italic">Boleta
                                                    (03)</span>
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                            </div>
                                            <p class="text-2xl font-black italic text-(--accent)">B001</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-[9px] font-black text-gray-600 uppercase mb-1">Correlativo
                                            </p>
                                            <p class="text-xl font-black font-mono">00008512</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-8 flex gap-4">
                                    <div class="flex-1 bg-white/5 p-4 rounded-2xl text-center border border-white/5">
                                        <p class="text-[8px] font-black text-gray-600 uppercase mb-1">Total Ventas</p>
                                        <p class="text-sm font-bold">10.2k</p>
                                    </div>
                                    <div class="flex-1 bg-white/5 p-4 rounded-2xl text-center border border-white/5">
                                        <p class="text-[8px] font-black text-gray-600 uppercase mb-1">Gastos Mes</p>
                                        <p class="text-sm font-bold">S/ 4.5k</p>
                                    </div>
                                </div>
                            </section>
                            {% endif %}

                            <button
                                class="bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-3 rounded-2xl text-xl font-bold flex items-center justify-center gap-2 transition-all shadow-xl shadow-orange-900/20 active:scale-95 cursor-pointer w-full">
                                Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {# Futura UPDATE
            <div id="view-network" class="tab-content space-y-8">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" id="network-stats">
                    <!-- Content inserted via JS if needed or static -->
                    <div class="bg-[#10141B] border border-[#1A1F26] p-8 rounded-3xl text-center">
                        <div class="text-[#FF4D00] mb-4 flex justify-center"><i data-lucide="server"
                                class="w-8 h-8"></i></div>
                        <p class="text-[9px] font-black uppercase text-gray-500 mb-1">Servidores</p>
                        <p class="text-2xl font-black italic text-white">24</p>
                    </div>
                    <div class="bg-[#10141B] border border-[#1A1F26] p-8 rounded-3xl text-center">
                        <div class="text-[#FF4D00] mb-4 flex justify-center"><i data-lucide="database"
                                class="w-8 h-8"></i></div>
                        <p class="text-[9px] font-black uppercase text-gray-500 mb-1">Storage</p>
                        <p class="text-2xl font-black italic text-white">1.2 PB</p>
                    </div>
                    <div class="bg-[#10141B] border border-[#1A1F26] p-8 rounded-3xl text-center">
                        <div class="text-[#FF4D00] mb-4 flex justify-center"><i data-lucide="wifi" class="w-8 h-8"></i>
                        </div>
                        <p class="text-[9px] font-black uppercase text-gray-500 mb-1">Nodos</p>
                        <p class="text-2xl font-black italic text-white">842</p>
                    </div>
                    <div class="bg-[#10141B] border border-[#1A1F26] p-8 rounded-3xl text-center">
                        <div class="text-[#FF4D00] mb-4 flex justify-center"><i data-lucide="layers"
                                class="w-8 h-8"></i></div>
                        <p class="text-[9px] font-black uppercase text-gray-500 mb-1">Uptime</p>
                        <p class="text-2xl font-black italic text-white">99.9%</p>
                    </div>
                </div>
                <div class="bg-[#0A0C10] border border-[#1A1F26] rounded-[3rem] overflow-hidden relative group">
                    <div class="p-10 border-b border-[#1A1F26] flex justify-between items-center relative z-10">
                        <h3 class="text-lg font-black italic uppercase">Mapa de Latencia Global</h3>
                        <div class="flex gap-4">
                            <span
                                class="flex items-center gap-2 text-[10px] font-black uppercase text-emerald-500"><span
                                    class="w-2 h-2 rounded-full bg-emerald-500"></span> Óptimo</span>
                            <span class="flex items-center gap-2 text-[10px] font-black uppercase text-red-500"><span
                                    class="w-2 h-2 rounded-full bg-red-500"></span> Crítico</span>
                        </div>
                    </div>
                    <div class="h-80 bg-[#050608] relative flex items-center justify-center overflow-hidden">
                        <div class="absolute inset-0 bg-grid opacity-10"></div>
                        <div class="z-10 text-center">
                            <i data-lucide="globe" class="mx-auto text-[#FF4D00] mb-6 animate-spin-slow w-16 h-16"></i>
                            <p class="text-[11px] font-black uppercase tracking-[0.4em] text-gray-500 animate-pulse">
                                Escaneando Tráfico en tiempo real...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div id="view-security" class="tab-content space-y-8">
                <div
                    class="bg-[#10141B] border border-[#1A1F26] p-12 rounded-[3rem] flex flex-col md:flex-row items-center gap-12">
